#!/bin/sh
# Prevents direct push to main — use PRs instead.
# Tags pushed from main are allowed.

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo ""
    echo "  pre-push: direct push to main is not allowed."
    echo "  Open a PR and squash merge instead."
    echo ""
    exit 1
  fi
done

exit 0
